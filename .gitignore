# History files
.Rhistory
*.Rhistory
.Rapp.history

# Session Data files
.RData
.RDataTmp

# User-specific files
.Ruserdata

# Example code in package build process
*-Ex.R

# Output files from R CMD build
/*.tar.gz

# Output files from R CMD check
/*.Rcheck/

# RStudio files
.Rproj.user/

# produced vignettes
vignettes/*.html
vignettes/*.pdf

# OAuth2 token, see https://github.com/hadley/httr/releases/tag/v0.3
.httr-oauth

# knitr and R markdown default cache directories
*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
.Renviron

# translation temp files
po/*~

# RStudio Connect folder
rsconnect/

# Databases (contain real assessment data - never commit)
*.db
databases/

# Claude Code session data
.claude/

# OS files
.DS_Store
Thumbs.db

# API keys (never commit)
**/API keys/
*.key

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
python/outputs/
python/gptr-mcp-master/
*.egg-info/
.eggs/
*.egg
.env
.venv/
venv/
python/.venv/
*.whl
pip-log.txt
pip-delete-this-directory.txt

# SQuAI corpus (generated data, not source)
python/SQuAI_scripts/squai_corpus/

# Windows reserved names (cause git errors)
nul
_ul
_ul*

# Species literature PDFs (large binary data, not source code)
species_literature/

# Tests folder (local test artifacts, not source)
tests/

# Docs folder (local documentation, not source)
docs/

# Nested git repos (use submodules if needed)
python/SQuAI_scripts/squai_repo/

# Log files
*.log
**/logs/

# Generated reports
assessment_report_*.docx

# IDE folders
.idea/

# Generated README (rendered from README.Rmd)
README.md

# Python instructions cache (generated)
python/instructions_cache/
.positai
